# =============================================
# 세이브픽 환경변수 설정
# .env.local.example → .env.local 로 복사 후 값 입력
# =============================================

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ── 🔴 전화번호 암호화 키 (필수) ──
# 32자 이상 랜덤 문자열. 절대 외부에 노출하지 마세요.
# 생성 방법: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=여기에_32자_이상의_랜덤_문자열_입력

# ── 카카오 OAuth ──
# 카카오 개발자센터 > 앱 > 앱 키 > REST API 키
KAKAO_REST_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 지점 코드 (지점별 배포 시 설정) ──
# hwajung / ulsan / nowon / seongnam / gwangmyung / daejeon / haeundae / bucheon / jeonju
NEXT_PUBLIC_BRANCH_ID=

# ── 취소 마감 설정 (픽업 당일 몇 시간 전까지 취소 허용) ──
CANCEL_DEADLINE_HOURS=24

# ── 운영 환경 ──
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
